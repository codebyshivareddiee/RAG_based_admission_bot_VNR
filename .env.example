# # =============================================================
# # VNRVJIET Admissions Chatbot – Environment Configuration
# # =============================================================
# # Copy this file to .env and fill in your credentials.

# # ── College Identity ──────────────────────────────────────────
# COLLEGE_NAME=VNR Vignana Jyothi Institute of Engineering and Technology
# COLLEGE_SHORT_NAME=VNRVJIET

# # ── OpenAI ────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# # ── Pinecone ──────────────────────────────────────────────────
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_INDEX_NAME=vnrvjiet-admissions
# PINECONE_ENVIRONMENT=us-east-1

# # ── Server Configuration ─────────────────────────────────────
# # IMPORTANT: All ports and URLs are now configurable via environment variables
# HOST=0.0.0.0
# 
# # Port for main chatbot application (Port 8000)
# # Run with: python railway_start.py
# PORT=8000
# 
# # Port for VNR admissions site with embedded chatbot (Port 8001)
# # Run with: python site_app_start.py
# SITE_PORT=8001
# 
# # Full URL where chatbot is accessible (used in site widget iframe)
# # LOCAL: http://localhost:8000/
# # PRODUCTION: https://api.yourdomain.com/ or https://yourdomain.com/
# CHATBOT_FULL_URL=http://localhost:8000/
# 
# # CORS allowed origins (comma-separated, no spaces)
# # LOCAL: http://localhost:8000,http://localhost:8001
# # PRODUCTION: https://yourdomain.com,https://www.yourdomain.com
# ALLOWED_ORIGINS=https://vnrvjiet.ac.in,http://localhost:8000,http://localhost:8001

# # ── Rate Limiting ─────────────────────────────────────────────
# RATE_LIMIT_PER_MINUTE=30

# # ── Database ──────────────────────────────────────────────────
# # MongoDB connection string
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/database_name

# # ── Firebase Firestore ────────────────────────────────────────
# # Download service account JSON from Firebase Console → Project Settings → Service Accounts
# FIREBASE_CREDENTIALS_JSON=app/data/firebase-service-account.json
# FIREBASE_PROJECT_ID=your-firebase-project-id

# # ── Google Sheets (Contact Requests) ──────────────────────────
# # RECOMMENDED: Easiest for admission staff to manage contact requests
# # 1. Create Google Sheet at https://sheets.google.com
# # 2. Get Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# # 3. Create service account in Google Cloud Console
# # 4. Download JSON key and place in project root
# # 5. Share sheet with service account email
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
# GOOGLE_SERVICE_ACCOUNT_PATH=google-service-account.json

# # ── Email Notifications (Optional) ────────────────────────────
# # Send email alerts when users submit contact requests
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_FROM_EMAIL=chatbot@vnrvjiet.ac.in
# SMTP_USERNAME=your-email@vnrvjiet.ac.in
# SMTP_PASSWORD=your-gmail-app-password
# ADMISSION_EMAIL=admissions@vnrvjiet.ac.in

# # ── Admin Dashboard (Optional) ────────────────────────────────
# # Password to access /admin/contacts dashboard
# ADMIN_PASSWORD=your-secure-password-here

# # ── Debug & Logging ───────────────────────────────────────────
# # Set to false in production
# DEBUG=false
# 
# # Cutoff snapshot path for caching
# CUTOFF_SNAPSHOT_PATH=./data/seed_data.json
# 
# # Enable web search fallback
# WEB_SEARCH_ENABLED=true
# 
# # Token limits
# MAX_TOKENS=2000
